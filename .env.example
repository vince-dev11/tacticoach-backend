# Database
DATABASE_URL="mysql://user:password@localhost:3306/tacticoach"

# Server
PORT=3001
NODE_ENV=development

# JWT — generate secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# AWS S3 (optional for local development)
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=tacticoach-uploads

# CORS — comma-separated allowed origins.
# In development, localhost and 127.0.0.1 origins are also allowed automatically.
CORS_ORIGINS=http://localhost:5280,https://yourdomain.com

# SMTP (optional — emails are skipped when unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM="TactiCoach <no-reply@tacticoach.co.uk>"
# Contact-form submissions are delivered here (defaults to MAIL_FROM)
SUPPORT_EMAIL=

# Frontend base URL (checkout redirects, invite + reset links)
FRONTEND_URL=http://localhost:5280

# Stripe (optional — billing routes return 503 when unset)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Gemini AI (optional — AI tactics routes return 503 when unset)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Company owner account — unlocks /admin (blog CMS + CRM)
OWNER_EMAIL=
