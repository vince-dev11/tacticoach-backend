generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id               Int       @id @default(autoincrement())
  // 'owner' unlocks the /admin area (blog CMS + CRM). Assigned only via the
  // OWNER_EMAIL env var — never through the API.
  role             Role      @default(user)
  name             String    @db.VarChar(100)
  surname          String    @db.VarChar(100)
  email            String    @unique @db.VarChar(191)
  phone            String?   @db.VarChar(30)
  passwordHash     String    @map("password_hash") @db.VarChar(255)
  clubName         String?   @map("club_name") @db.VarChar(150)
  clubLogoUrl      String?   @map("club_logo_url") @db.VarChar(500)
  clubLogoKey      String?   @map("club_logo_key") @db.VarChar(500)
  // Social links shown on exported drill sheets.
  instagramUrl     String?   @map("instagram_url") @db.VarChar(300)
  youtubeUrl       String?   @map("youtube_url") @db.VarChar(300)
  twitterUrl       String?   @map("twitter_url") @db.VarChar(300)
  facebookUrl      String?   @map("facebook_url") @db.VarChar(300)
  stripeCustomerId String?   @unique @map("stripe_customer_id") @db.VarChar(191)
  emailVerifiedAt  DateTime? @map("email_verified_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  subscription        UserSubscription?
  boards              CanvasBoard[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  boardLikes          BoardLike[]
  // Purchased top-up credits (never expire) — spent only after the plan's
  // monthly allowance is exhausted.
  bonusCredits Int @default(0) @map("bonus_credits")

  ownedClub       Club?             @relation("ClubOwner")
  clubMembership  ClubMember?
  drillSheets     DrillSheet[]
  drillSheetLikes DrillSheetLike[]
  aiUsage         AiUsage[]

  @@map("users")
}

/// One row per successful AI generation — the plan's monthly allowance is
/// enforced by counting rows in the current calendar month (no refill job).
model AiUsage {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  kind      AiKind
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("ai_usage")
}

enum AiKind {
  layout
  animation
  reel
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String   @unique @db.VarChar(191)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// Single-use password-reset tokens. Only the SHA-256 hash of the token is stored,
// so a DB leak can't be used to reset accounts. Expires after a short window.
model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// Membership plans — pricing to be decided; price fields nullable until set.
model MembershipPlan {
  id             Int      @id @default(autoincrement())
  name           String   @db.VarChar(100)
  slug           String   @unique @db.VarChar(50)
  description    String?  @db.Text
  monthlyPrice   Decimal? @map("monthly_price") @db.Decimal(10, 2)
  annualPrice    Decimal? @map("annual_price") @db.Decimal(10, 2)
  currency       String   @default("EUR") @db.VarChar(3)
  features       Json     @default("[]")
  maxBoards      Int?     @map("max_boards")
  maxTeamMembers Int?     @map("max_team_members")
  isActive       Boolean  @default(true) @map("is_active")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  subscriptions UserSubscription[]

  @@map("membership_plans")
}

model UserSubscription {
  id                     Int                @id @default(autoincrement())
  userId                 Int                @unique @map("user_id")
  planId                 Int                @map("plan_id")
  status                 SubscriptionStatus @default(trial)
  billingCycle           BillingCycle?      @map("billing_cycle")
  startedAt              DateTime           @default(now()) @map("started_at")
  expiresAt              DateTime?          @map("expires_at")
  // Set once the "trial ends in 2 days" reminder email has gone out (dedupe).
  trialReminderSentAt    DateTime?          @map("trial_reminder_sent_at")
  cancelledAt            DateTime?          @map("cancelled_at")
  paymentProvider        String?            @map("payment_provider") @db.VarChar(50)
  providerSubscriptionId String?            @map("provider_subscription_id") @db.VarChar(255)
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan MembershipPlan @relation(fields: [planId], references: [id])

  @@index([planId])
  @@map("user_subscriptions")
}

enum SubscriptionStatus {
  trial
  active
  cancelled
  expired
}

enum BillingCycle {
  monthly
  annual
}

model CanvasBoard {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  title        String    @db.VarChar(255)
  pitchKey     String?   @map("pitch_key") @db.VarChar(50)
  state        Json      @default("{}")
  // S3 object keys — URLs are presigned on read, never stored.
  thumbnailKey String?   @map("thumbnail_key") @db.VarChar(500)
  videoKey     String?   @map("video_key") @db.VarChar(500)
  // Legacy column kept for compatibility with earlier clients.
  thumbnailUrl String?   @map("thumbnail_url") @db.VarChar(500)
  // Boards are public by default (the create route also sets this explicitly).
  published    Boolean   @default(true)
  publishedAt  DateTime? @map("published_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes BoardLike[]

  @@index([userId])
  @@index([published, publishedAt])
  @@map("canvas_boards")
}

model BoardLike {
  id        Int      @id @default(autoincrement())
  boardId   Int      @map("board_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  board CanvasBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@index([userId])
  @@map("board_likes")
}

// ---- Clubs (Club plan: owner buys seats, invites coaches) -------------------

model Club {
  id        Int      @id @default(autoincrement())
  ownerId   Int      @unique @map("owner_id")
  name      String   @db.VarChar(150)
  // ---- Brand kit (set once by the owner in Club → Branding) ----
  badgeKey       String?    @map("badge_key") @db.VarChar(500)
  primaryColor   String?    @map("primary_color") @db.VarChar(9)
  secondaryColor String?    @map("secondary_color") @db.VarChar(9)
  slug           String?    @unique @db.VarChar(80)
  bio            String?    @db.Text
  location       String?    @db.VarChar(150)
  foundedYear    Int?       @map("founded_year")
  // Public page lifecycle: content gate + owner submission + CRM approval.
  pageStatus      PageStatus @default(none) @map("page_status")
  pageSubmittedAt DateTime?  @map("page_submitted_at")
  pageReviewNote  String?    @map("page_review_note") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner   User         @relation("ClubOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members ClubMember[]
  invites ClubInvite[]
  photos  ClubPhoto[]

  @@map("clubs")
}

model ClubMember {
  id        Int      @id @default(autoincrement())
  clubId    Int      @map("club_id")
  userId    Int      @unique @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@map("club_members")
}

model ClubInvite {
  id         Int       @id @default(autoincrement())
  clubId     Int       @map("club_id")
  email      String    @db.VarChar(255)
  token      String    @unique @db.VarChar(100)
  acceptedAt DateTime? @map("accepted_at")
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@map("club_invites")
}

// ---- Drill sheets (data sheets — publishable, likeable) ---------------------

model DrillSheet {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  title       String    @db.VarChar(255)
  description String?   @db.Text
  data        Json      @default("{}")
  // S3 key of the rendered sheet image (preview shown in the gallery).
  imageKey    String?   @map("image_key") @db.VarChar(500)
  // Sheets are public by default (the create route also sets this explicitly).
  published   Boolean   @default(true)
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes DrillSheetLike[]

  @@index([userId])
  @@index([published, publishedAt])
  @@map("drill_sheets")
}

model DrillSheetLike {
  id        Int      @id @default(autoincrement())
  sheetId   Int      @map("sheet_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  sheet DrillSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sheetId, userId])
  @@index([userId])
  @@map("drill_sheet_likes")
}

enum Role {
  user
  owner
}

// ---- Blog (marketing content, owner-managed) --------------------------------

model BlogPost {
  id             Int       @id @default(autoincrement())
  slug           String    @unique @db.VarChar(200)
  title          String    @db.VarChar(255)
  excerpt        String?   @db.Text
  // Markdown source; rendered client-side.
  content        String    @db.LongText
  coverImageKey  String?   @map("cover_image_key") @db.VarChar(500)
  tags           Json      @default("[]")
  status         PostStatus @default(draft)
  publishedAt    DateTime? @map("published_at")
  authorId       Int       @map("author_id")
  seoTitle       String?   @map("seo_title") @db.VarChar(255)
  seoDescription String?   @map("seo_description") @db.VarChar(320)
  readMinutes    Int       @default(3) @map("read_minutes")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([status, publishedAt])
  @@map("blog_posts")
}

enum PostStatus {
  draft
  published
}

// ---- CRM leads (contact form submissions) ------------------------------------

model ContactMessage {
  id        Int           @id @default(autoincrement())
  firstName String        @map("first_name") @db.VarChar(100)
  lastName  String        @map("last_name") @db.VarChar(100)
  email     String        @db.VarChar(255)
  message   String        @db.Text
  status    LeadStatus    @default(new)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@map("contact_messages")
}

enum LeadStatus {
  new
  replied
  closed
}

enum PageStatus {
  none
  pending
  approved
  rejected
  suspended
}

// Gallery photos on the public club page — awards, trophies, team photos,
// facilities. Capped at 8 per club in the upload route.
model ClubPhoto {
  id        Int      @id @default(autoincrement())
  clubId    Int      @map("club_id")
  imageKey  String   @map("image_key") @db.VarChar(500)
  caption   String?  @db.VarChar(200)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId, sortOrder])
  @@map("club_photos")
}
